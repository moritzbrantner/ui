{
  "name": "@moritzbrantner/ui",
  "version": "0.5.3",
  "private": false,
  "description": "Shared Tailwind 4 React UI primitives, themes, and layout components for platform packages.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzbrantner/ui.git"
  },
  "files": [
    "dist",
    "styles.css",
    "theme-scopes.css",
    "zleek",
    "bobba",
    "atlas",
    "studio",
    "paper"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./zleek": {
      "types": "./dist/zleek.d.ts",
      "import": "./dist/zleek.js"
    },
    "./bobba": {
      "types": "./dist/bobba.d.ts",
      "import": "./dist/bobba.js"
    },
    "./atlas": {
      "types": "./dist/atlas.d.ts",
      "import": "./dist/atlas.js"
    },
    "./studio": {
      "types": "./dist/studio.d.ts",
      "import": "./dist/studio.js"
    },
    "./paper": {
      "types": "./dist/paper.d.ts",
      "import": "./dist/paper.js"
    },
    "./themes": {
      "types": "./dist/themes.d.ts",
      "import": "./dist/themes.js"
    },
    "./lib/cn": {
      "types": "./dist/lib/cn.d.ts",
      "import": "./dist/lib/cn.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./styles.css": "./styles.css",
    "./theme-scopes.css": "./theme-scopes.css",
    "./zleek/styles.css": "./zleek/styles.css",
    "./bobba/styles.css": "./bobba/styles.css",
    "./atlas/styles.css": "./atlas/styles.css",
    "./studio/styles.css": "./studio/styles.css",
    "./paper/styles.css": "./paper/styles.css"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build-storybook": "storybook build --output-dir storybook-static",
    "bench": "node ./scripts/benchmark-ui.mjs",
    "bench:update": "node ./scripts/benchmark-ui.mjs --update",
    "check-types": "tsc --noEmit",
    "lint": "node ./scripts/verify-design-system.mjs && node ./scripts/verify-tokens.mjs && node ./scripts/verify-package-imports.mjs ./src @/ next/ && node ./scripts/verify-package-styles.mjs .",
    "pack:dry": "npm pack --dry-run --ignore-scripts --json",
    "prepack": "bun run build",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "bun run test:unit",
    "test:coverage": "node ./scripts/run-coverage.mjs",
    "test:package": "node ./scripts/verify-package.mjs",
    "test:storybook": "vitest --config vitest.storybook.config.ts --project=storybook --run",
    "test:unit": "vitest run src",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "verify:build-size": "node ./scripts/verify-build-size.mjs",
    "verify:consumer": "node ./scripts/verify-consumer-build.mjs",
    "verify:release": "bun run check-types && bun run lint && bun run test:unit && bun run build && bun run test:package && bun run test:storybook && bun run test:coverage && bun run test:visual && bun run verify:consumer && bun run verify:build-size && bun run bench && bun run pack:dry",
    "verify:tokens": "node ./scripts/verify-tokens.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.35.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@react-three/fiber": "^9.4.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.5",
    "three": "^0.180.0",
    "tsup": "^8.5.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
