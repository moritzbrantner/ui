{
  "name": "@moritzbrantner/ui",
  "version": "0.9.1",
  "private": false,
  "description": "Shared Tailwind 4 React UI primitives, themes, and layout components for platform packages.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzbrantner/ui.git"
  },
  "files": [
    "dist",
    "styles.css",
    "theme-scopes.css",
    "zleek",
    "bobba",
    "atlas",
    "studio",
    "paper"
  ],
  "type": "module",
  "packageManager": "bun@1.3.12",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./stable": {
      "types": "./dist/stable.d.ts",
      "import": "./dist/stable.js"
    },
    "./patterns": {
      "types": "./dist/patterns.d.ts",
      "import": "./dist/patterns.js"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js"
    },
    "./social": {
      "types": "./dist/social.d.ts",
      "import": "./dist/social.js"
    },
    "./media": {
      "types": "./dist/media.d.ts",
      "import": "./dist/media.js"
    },
    "./labs": {
      "types": "./dist/labs.d.ts",
      "import": "./dist/labs.js"
    },
    "./zleek": {
      "types": "./dist/zleek.d.ts",
      "import": "./dist/zleek.js"
    },
    "./zleek/server": {
      "types": "./dist/zleek/server.d.ts",
      "import": "./dist/zleek/server.js"
    },
    "./bobba": {
      "types": "./dist/bobba.d.ts",
      "import": "./dist/bobba.js"
    },
    "./bobba/server": {
      "types": "./dist/bobba/server.d.ts",
      "import": "./dist/bobba/server.js"
    },
    "./atlas": {
      "types": "./dist/atlas.d.ts",
      "import": "./dist/atlas.js"
    },
    "./atlas/server": {
      "types": "./dist/atlas/server.d.ts",
      "import": "./dist/atlas/server.js"
    },
    "./studio": {
      "types": "./dist/studio.d.ts",
      "import": "./dist/studio.js"
    },
    "./studio/server": {
      "types": "./dist/studio/server.d.ts",
      "import": "./dist/studio/server.js"
    },
    "./paper": {
      "types": "./dist/paper.d.ts",
      "import": "./dist/paper.js"
    },
    "./paper/server": {
      "types": "./dist/paper/server.d.ts",
      "import": "./dist/paper/server.js"
    },
    "./themes": {
      "types": "./dist/themes.d.ts",
      "import": "./dist/themes.js"
    },
    "./lib/cn": {
      "types": "./dist/lib/cn.d.ts",
      "import": "./dist/lib/cn.js"
    },
    "./components/stable/*": {
      "types": "./dist/components/stable/*.d.ts",
      "import": "./dist/components/stable/*.js"
    },
    "./components/patterns/*": {
      "types": "./dist/components/patterns/*.d.ts",
      "import": "./dist/components/patterns/*.js"
    },
    "./components/data/*": {
      "types": "./dist/components/data/*.d.ts",
      "import": "./dist/components/data/*.js"
    },
    "./components/shell/*": {
      "types": "./dist/components/shell/*.d.ts",
      "import": "./dist/components/shell/*.js"
    },
    "./components/social/*": {
      "types": "./dist/components/social/*.d.ts",
      "import": "./dist/components/social/*.js"
    },
    "./components/media/*": {
      "types": "./dist/components/media/*.d.ts",
      "import": "./dist/components/media/*.js"
    },
    "./components/labs/*": {
      "types": "./dist/components/labs/*.d.ts",
      "import": "./dist/components/labs/*.js"
    },
    "./styles.css": "./styles.css",
    "./theme-scopes.css": "./theme-scopes.css",
    "./zleek/styles.css": "./zleek/styles.css",
    "./bobba/styles.css": "./bobba/styles.css",
    "./atlas/styles.css": "./atlas/styles.css",
    "./studio/styles.css": "./studio/styles.css",
    "./paper/styles.css": "./paper/styles.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build-storybook": "storybook build --output-dir storybook-static",
    "bench": "bun ./scripts/benchmark-ui.ts",
    "bench:update": "bun ./scripts/benchmark-ui.ts --update",
    "check:hygiene": "bash ./scripts/check_repo_hygiene.sh",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "dev": "bun run storybook",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "bun ./scripts/verify-design-system.ts && bun ./scripts/verify-state-selectors.ts && bun ./scripts/verify-tokens.ts && bun ./scripts/verify-package-imports.ts ./src @/ next/ && bun ./scripts/verify-package-styles.ts . && bun ./scripts/verify-docs-links.ts && bun run verify:mobile-usability-skips",
    "pack:dry": "bun pm pack --dry-run --ignore-scripts",
    "perf:report": "bun ./scripts/report-performance-hotspots.ts",
    "prepack": "bun run build",
    "publish:registry": "bun run verify:release && bun publish --access public",
    "storybook": "storybook dev -p 6006 --no-open",
    "test": "bun run test:unit",
    "test:coverage": "bun ./scripts/run-coverage.ts",
    "test:package": "bun ./scripts/verify-package.ts",
    "test:storybook": "vitest --config vitest.storybook.config.ts --project=storybook --run",
    "test:unit": "vitest run src",
    "test:unlighthouse": "bun run build-storybook && bun ./scripts/run-unlighthouse.ts",
    "test:mobile-usability": "playwright test --config playwright.visual.config.ts visual/mobile-usability.spec.ts",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "verify:build-size": "bun ./scripts/verify-build-size.ts",
    "verify:consumer": "bun ./scripts/verify-consumer-build.ts",
    "verify:state-selectors": "bun ./scripts/verify-state-selectors.ts",
    "verify": "bun run check:hygiene && bun run verify:release",
    "verify:mobile-usability-skips": "bun ./scripts/verify-mobile-usability-skips.ts",
    "verify:release:ci": "bun run check-types && bun run lint && bun run test:unit && bun run build && bun run test:package && bun run test:storybook && bun run test:coverage && bun run test:visual && bun run test:mobile-usability && bun run test:unlighthouse && bun run verify:consumer && bun run verify:build-size && bun run bench && bun run pack:dry",
    "verify:release": "bun run check-types && bun run lint && bun run test:unit && bun run build && bun run test:package && bun run test:storybook && bun run test:coverage && bun run test:visual && bun run test:mobile-usability && bun run test:unlighthouse && bun run verify:consumer && bun run verify:build-size && bun run bench && bun run pack:dry",
    "verify:tokens": "bun ./scripts/verify-tokens.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@react-three/fiber": "^9.4.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/react": "^16.3.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "4.1.6",
    "jsdom": "^26.1.0",
    "oxfmt": "0.51.0",
    "playwright": "^1.59.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.5",
    "three": "^0.180.0",
    "tsup": "^8.5.0",
    "unlighthouse": "^0.17.9",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
